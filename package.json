{
  "name": "saropa-package-vibrancy",
  "displayName": "Saropa Package Vibrancy",
  "description": "Analyze Flutter/Dart dependency health and community vibrancy",
  "version": "0.2.0",
  "publisher": "saropa",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/saropa/saropa-package-vibrancy"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "flutter",
    "dart",
    "pubspec",
    "vibrancy",
    "dependency",
    "health"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saropaPackageVibrancy",
          "title": "Package Vibrancy",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "saropaPackageVibrancy": [
        {
          "id": "saropaPackageVibrancy.packages",
          "name": "Packages",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "saropaPackageVibrancy.scan",
        "title": "Saropa: Scan Package Vibrancy",
        "icon": "$(refresh)"
      },
      {
        "command": "saropaPackageVibrancy.showReport",
        "title": "Saropa: Show Vibrancy Report",
        "icon": "$(graph)"
      },
      {
        "command": "saropaPackageVibrancy.clearCache",
        "title": "Saropa: Clear Cache",
        "icon": "$(trash)"
      },
      {
        "command": "saropaPackageVibrancy.exportReport",
        "title": "Saropa: Export Vibrancy Report",
        "icon": "$(export)"
      },
      {
        "command": "saropaPackageVibrancy.browseKnownIssues",
        "title": "Saropa: Browse Known Issues Library",
        "icon": "$(library)"
      },
      {
        "command": "saropaPackageVibrancy.about",
        "title": "Saropa: About",
        "icon": "$(info)"
      },
      {
        "command": "saropaPackageVibrancy.exportSbom",
        "title": "Saropa: Export SBOM (CycloneDX)",
        "icon": "$(shield)"
      },
      {
        "command": "saropaPackageVibrancy.annotatePubspec",
        "title": "Saropa: Annotate Dependencies",
        "icon": "$(note)"
      },
      {
        "command": "saropaPackageVibrancy.goToPackage",
        "title": "Go to pubspec.yaml",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaPackageVibrancy.openOnPubDev",
        "title": "Open on pub.dev",
        "icon": "$(link-external)"
      },
      {
        "command": "saropaPackageVibrancy.updateToLatest",
        "title": "Update to Latest",
        "icon": "$(arrow-up)"
      },
      {
        "command": "saropaPackageVibrancy.copyAsJson",
        "title": "Copy as JSON",
        "icon": "$(clippy)"
      },
      {
        "command": "saropaPackageVibrancy.upgradeAndTest",
        "title": "Upgrade & Test",
        "icon": "$(beaker)"
      },
      {
        "command": "saropaPackageVibrancy.suppressPackage",
        "title": "Suppress Package",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.unsuppressPackage",
        "title": "Unsuppress Package",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.openUrl",
        "title": "Open Link",
        "icon": "$(link-external)"
      },
      {
        "command": "saropaPackageVibrancy.commentOutUnused",
        "title": "Comment Out Unused Dependency",
        "icon": "$(comment)"
      },
      {
        "command": "saropaPackageVibrancy.deleteUnused",
        "title": "Delete Unused Dependency (with backup)",
        "icon": "$(trash)"
      },
      {
        "command": "saropaPackageVibrancy.planUpgrades",
        "title": "Saropa: Plan & Execute Upgrades",
        "icon": "$(rocket)"
      },
      {
        "command": "saropaPackageVibrancy.suppressPackageByName",
        "title": "Suppress Package Diagnostics"
      },
      {
        "command": "saropaPackageVibrancy.suppressByCategory",
        "title": "Saropa: Suppress by Category...",
        "icon": "$(filter)"
      },
      {
        "command": "saropaPackageVibrancy.suppressAllProblems",
        "title": "Saropa: Suppress All Unhealthy Packages",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.unsuppressAll",
        "title": "Saropa: Unsuppress All Packages",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.sortDependencies",
        "title": "Saropa: Sort Dependencies Alphabetically",
        "icon": "$(list-ordered)"
      },
      {
        "command": "saropaPackageVibrancy.showCodeLens",
        "title": "Saropa: Show Vibrancy Badges",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.hideCodeLens",
        "title": "Saropa: Hide Vibrancy Badges",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.toggleCodeLens",
        "title": "Saropa: Toggle Vibrancy Badges"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "saropaPackageVibrancy.scan",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "navigation@1"
        },
        {
          "command": "saropaPackageVibrancy.about",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "navigation@2"
        },
        {
          "command": "saropaPackageVibrancy.planUpgrades",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "navigation@3"
        },
        {
          "command": "saropaPackageVibrancy.annotatePubspec",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "navigation@4"
        },
        {
          "command": "saropaPackageVibrancy.suppressByCategory",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.unsuppressAll",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "suppress@2"
        },
        {
          "command": "saropaPackageVibrancy.sortDependencies",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "organize@1"
        }
      ],
      "editor/title": [
        {
          "command": "saropaPackageVibrancy.hideCodeLens",
          "when": "resourceFilename == pubspec.yaml && saropaPackageVibrancy.codeLensEnabled",
          "group": "navigation"
        },
        {
          "command": "saropaPackageVibrancy.showCodeLens",
          "when": "resourceFilename == pubspec.yaml && !saropaPackageVibrancy.codeLensEnabled",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "saropaPackageVibrancy.sortDependencies",
          "when": "resourceFilename == pubspec.yaml",
          "group": "saropa@1"
        }
      ],
      "commandPalette": [
        {
          "command": "saropaPackageVibrancy.showCodeLens",
          "when": "!saropaPackageVibrancy.codeLensEnabled"
        },
        {
          "command": "saropaPackageVibrancy.hideCodeLens",
          "when": "saropaPackageVibrancy.codeLensEnabled"
        }
      ],
      "view/item/context": [
        {
          "command": "saropaPackageVibrancy.goToPackage",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "inline"
        },
        {
          "command": "saropaPackageVibrancy.goToPackage",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@1"
        },
        {
          "command": "saropaPackageVibrancy.openOnPubDev",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@2"
        },
        {
          "command": "saropaPackageVibrancy.updateToLatest",
          "when": "viewItem == vibrancyPackageUpdatable",
          "group": "navigation@3"
        },
        {
          "command": "saropaPackageVibrancy.copyAsJson",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@4"
        },
        {
          "command": "saropaPackageVibrancy.upgradeAndTest",
          "when": "viewItem == vibrancyPackageUpdatable",
          "group": "navigation@5"
        },
        {
          "command": "saropaPackageVibrancy.suppressPackage",
          "when": "viewItem =~ /^vibrancyPackage(Unused)?(Updatable)?$/",
          "group": "2_suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.unsuppressPackage",
          "when": "viewItem =~ /Suppressed/",
          "group": "2_suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.openUrl",
          "when": "viewItem == vibrancyDetailLink",
          "group": "inline"
        },
        {
          "command": "saropaPackageVibrancy.commentOutUnused",
          "when": "viewItem =~ /vibrancyPackageUnused/",
          "group": "3_unused@1"
        },
        {
          "command": "saropaPackageVibrancy.deleteUnused",
          "when": "viewItem =~ /vibrancyPackageUnused/",
          "group": "3_unused@2"
        }
      ]
    },
    "configuration": {
      "title": "Saropa Package Vibrancy",
      "properties": {
        "saropaPackageVibrancy.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token for increased API rate limits (60/hr without, 5000/hr with)"
        },
        "saropaPackageVibrancy.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan when a Flutter project is opened"
        },
        "saropaPackageVibrancy.includeDevDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Include dev_dependencies in the vibrancy scan"
        },
        "saropaPackageVibrancy.cacheTtlHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 168,
          "description": "Cache TTL in hours for API responses"
        },
        "saropaPackageVibrancy.suppressedPackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to suppress from vibrancy diagnostics and hover (still scanned, shown dimmed in tree)"
        },
        "saropaPackageVibrancy.allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to skip during vibrancy scan (e.g. internal packages)"
        },
        "saropaPackageVibrancy.repoOverrides": {
          "type": "object",
          "default": {},
          "description": "Override GitHub repository URLs for packages where pub.dev data is wrong. Keys are package names, values are GitHub URLs (e.g. { \"my_pkg\": \"https://github.com/org/my_pkg\" })",
          "additionalProperties": {
            "type": "string"
          }
        },
        "saropaPackageVibrancy.showLockDiffNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification summarizing lock file changes after each scan"
        },
        "saropaPackageVibrancy.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show vibrancy score badges as CodeLens annotations above each dependency in pubspec.yaml"
        },
        "saropaPackageVibrancy.enableAdoptionGate": {
          "type": "boolean",
          "default": true,
          "description": "Show inline vibrancy badges for new packages being added to pubspec.yaml"
        },
        "saropaPackageVibrancy.codeLensDetail": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "full"
          ],
          "default": "standard",
          "enumDescriptions": [
            "Score and category only",
            "Score, category, and update status",
            "Score, category, archive size, update status, and alerts"
          ],
          "description": "Controls how much detail the CodeLens annotations show"
        },
        "saropaPackageVibrancy.indicators": {
          "type": "object",
          "default": {},
          "description": "Custom symbols for status indicators. Keys: vibrant, quiet, legacyLocked, endOfLife, updateAvailable, prerelease, warning, error, unused, suppressed, upToDate",
          "properties": {
            "vibrant": { "type": "string", "description": "Indicator for vibrant packages (default: 🟢)" },
            "quiet": { "type": "string", "description": "Indicator for quiet packages (default: 🟡)" },
            "legacyLocked": { "type": "string", "description": "Indicator for legacy-locked packages (default: 🟠)" },
            "endOfLife": { "type": "string", "description": "Indicator for end-of-life packages (default: 🔴)" },
            "updateAvailable": { "type": "string", "description": "Indicator for available updates (default: ⬆)" },
            "warning": { "type": "string", "description": "Indicator for warnings (default: ⚠)" },
            "unused": { "type": "string", "description": "Indicator for unused packages (default: 👻)" },
            "upToDate": { "type": "string", "description": "Indicator for up-to-date packages (default: ✓)" }
          }
        },
        "saropaPackageVibrancy.indicatorStyle": {
          "type": "string",
          "enum": [
            "emoji",
            "text",
            "both",
            "none"
          ],
          "default": "emoji",
          "enumDescriptions": [
            "Show emoji only (🟢)",
            "Show text only (Vibrant)",
            "Show both (🟢 Vibrant)",
            "Show score only, no indicator"
          ],
          "description": "How to display status indicators in CodeLens"
        },
        "saropaPackageVibrancy.sortSdkFirst": {
          "type": "boolean",
          "default": true,
          "description": "Keep SDK dependencies (flutter, flutter_test) at the top when sorting"
        },
        "saropaPackageVibrancy.endOfLifeDiagnostics": {
          "type": "string",
          "enum": [
            "none",
            "hint",
            "smart"
          ],
          "default": "none",
          "enumDescriptions": [
            "No diagnostics for end-of-life packages (view in sidebar only)",
            "Show as Hint (subtle underline)",
            "Show as Warning only when a replacement is known, otherwise Hint"
          ],
          "description": "How to display end-of-life package diagnostics in the editor"
        },
        "saropaPackageVibrancy.weights.resolutionVelocity": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Resolution Velocity in V_score (default 0.5)"
        },
        "saropaPackageVibrancy.weights.engagementLevel": {
          "type": "number",
          "default": 0.4,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Engagement Level in V_score (default 0.4)"
        },
        "saropaPackageVibrancy.weights.popularity": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Popularity in V_score (default 0.1)"
        },
        "saropaPackageVibrancy.publisherTrustBonus": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 25,
          "description": "Max bonus for major trusted publishers like dart.dev (0 to disable). Verified publishers get 1/3, no publisher gets \u22121/3 penalty."
        },
        "saropaPackageVibrancy.upgradeSkipTests": {
          "type": "boolean",
          "default": false,
          "description": "Skip flutter test gates during upgrade execution (faster but less safe)"
        },
        "saropaPackageVibrancy.upgradeMaxSteps": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of upgrade steps to execute in one run"
        },
        "saropaPackageVibrancy.watchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable background polling for new package versions"
        },
        "saropaPackageVibrancy.watchIntervalHours": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 24,
          "description": "How often to check for new package versions (in hours)"
        },
        "saropaPackageVibrancy.watchFilter": {
          "type": "string",
          "enum": [
            "all",
            "unhealthy",
            "custom"
          ],
          "default": "all",
          "enumDescriptions": [
            "Watch all direct dependencies",
            "Only watch packages with vibrancy score below 40",
            "Only watch packages specified in watchList"
          ],
          "description": "Filter which packages to watch for new versions"
        },
        "saropaPackageVibrancy.watchList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to watch for new versions (only used when watchFilter is 'custom')"
        },
        "saropaPackageVibrancy.annotateSectionHeaders": {
          "type": "boolean",
          "default": true,
          "description": "Insert decorative section headers above major pubspec sections (dependencies, dev_dependencies, dependency_overrides)"
        },
        "saropaPackageVibrancy.treeGrouping": {
          "type": "string",
          "enum": [
            "none",
            "section"
          ],
          "default": "none",
          "enumDescriptions": [
            "Flat list sorted by vibrancy score (worst first)",
            "Group by pubspec section (dependencies, dev_dependencies)"
          ],
          "description": "How to group packages in the tree view"
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "compile-tests": "tsc -p ./",
    "lint": "eslint src",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "pretest": "npm run compile-tests",
    "test": "mocha",
    "vscode:prepublish": "npm run package",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.15.0",
    "mocha": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "semver": "^7.7.4",
    "sinon": "^19.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0"
  }
}
