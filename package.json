{
  "name": "saropa-package-vibrancy",
  "displayName": "Saropa Package Vibrancy",
  "description": "Analyze Flutter/Dart dependency health and community vibrancy",
  "version": "1.4.0",
  "publisher": "saropa",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/saropa/saropa-package-vibrancy"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "flutter",
    "dart",
    "pubspec",
    "vibrancy",
    "dependency",
    "health"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saropaPackageVibrancy",
          "title": "Package Vibrancy",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "saropaPackageVibrancy": [
        {
          "id": "saropaPackageVibrancy.packages",
          "name": "Packages",
          "icon": "images/sidebar-icon.svg"
        },
        {
          "id": "saropaPackageVibrancy.problems",
          "name": "Problems",
          "icon": "$(warning)"
        },
        {
          "id": "saropaPackageVibrancy.details",
          "name": "Package Details",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "saropaPackageVibrancy.scan",
        "title": "Saropa: Scan Package Vibrancy",
        "icon": "$(refresh)"
      },
      {
        "command": "saropaPackageVibrancy.showReport",
        "title": "Saropa: Show Vibrancy Report",
        "icon": "$(graph)"
      },
      {
        "command": "saropaPackageVibrancy.clearCache",
        "title": "Saropa: Clear Cache",
        "icon": "$(trash)"
      },
      {
        "command": "saropaPackageVibrancy.exportReport",
        "title": "Saropa: Export Vibrancy Report",
        "icon": "$(export)"
      },
      {
        "command": "saropaPackageVibrancy.browseKnownIssues",
        "title": "Saropa: Browse Known Issues Library",
        "icon": "$(library)"
      },
      {
        "command": "saropaPackageVibrancy.about",
        "title": "Saropa: About",
        "icon": "$(info)"
      },
      {
        "command": "saropaPackageVibrancy.exportSbom",
        "title": "Saropa: Export SBOM (CycloneDX)",
        "icon": "$(shield)"
      },
      {
        "command": "saropaPackageVibrancy.annotatePubspec",
        "title": "Saropa: Annotate Dependencies",
        "icon": "$(note)"
      },
      {
        "command": "saropaPackageVibrancy.goToPackage",
        "title": "Go to pubspec.yaml",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaPackageVibrancy.goToLine",
        "title": "Go to line in pubspec.yaml",
        "icon": "$(go-to-file)"
      },
      {
        "command": "saropaPackageVibrancy.openOnPubDev",
        "title": "Open on pub.dev",
        "icon": "$(link-external)"
      },
      {
        "command": "saropaPackageVibrancy.showChangelog",
        "title": "Open Changelog on pub.dev",
        "icon": "$(book)"
      },
      {
        "command": "saropaPackageVibrancy.updateToLatest",
        "title": "Update to Latest",
        "icon": "$(arrow-up)"
      },
      {
        "command": "saropaPackageVibrancy.copyAsJson",
        "title": "Copy as JSON",
        "icon": "$(clippy)"
      },
      {
        "command": "saropaPackageVibrancy.upgradeAndTest",
        "title": "Upgrade & Test",
        "icon": "$(beaker)"
      },
      {
        "command": "saropaPackageVibrancy.suppressPackage",
        "title": "Suppress Package",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.unsuppressPackage",
        "title": "Unsuppress Package",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.openUrl",
        "title": "Open Link",
        "icon": "$(link-external)"
      },
      {
        "command": "saropaPackageVibrancy.commentOutUnused",
        "title": "Comment Out Unused Dependency",
        "icon": "$(comment)"
      },
      {
        "command": "saropaPackageVibrancy.deleteUnused",
        "title": "Delete Unused Dependency (with backup)",
        "icon": "$(trash)"
      },
      {
        "command": "saropaPackageVibrancy.planUpgrades",
        "title": "Saropa: Plan & Execute Upgrades",
        "icon": "$(rocket)"
      },
      {
        "command": "saropaPackageVibrancy.suppressPackageByName",
        "title": "Suppress Package Diagnostics"
      },
      {
        "command": "saropaPackageVibrancy.suppressByCategory",
        "title": "Saropa: Suppress by Category...",
        "icon": "$(filter)"
      },
      {
        "command": "saropaPackageVibrancy.suppressAllProblems",
        "title": "Saropa: Suppress All Unhealthy Packages",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.unsuppressAll",
        "title": "Saropa: Unsuppress All Packages",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.sortDependencies",
        "title": "Saropa: Sort Dependencies Alphabetically",
        "icon": "$(list-ordered)"
      },
      {
        "command": "saropaPackageVibrancy.showCodeLens",
        "title": "Saropa: Show Vibrancy Badges",
        "icon": "$(eye)"
      },
      {
        "command": "saropaPackageVibrancy.hideCodeLens",
        "title": "Saropa: Hide Vibrancy Badges",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.toggleCodeLens",
        "title": "Saropa: Toggle Vibrancy Badges"
      },
      {
        "command": "saropaPackageVibrancy.focusDetails",
        "title": "Saropa: Focus Package Details",
        "icon": "$(preview)"
      },
      {
        "command": "saropaPackageVibrancy.logDetails",
        "title": "Log to Output",
        "icon": "$(output)"
      },
      {
        "command": "saropaPackageVibrancy.logAllDetails",
        "title": "Saropa: Log All Package Details",
        "icon": "$(output)"
      },
      {
        "command": "saropaPackageVibrancy.updateFromCodeLens",
        "title": "Update Package Version"
      },
      {
        "command": "saropaPackageVibrancy.focusPackageInTree",
        "title": "Show Package in Tree View"
      },
      {
        "command": "saropaPackageVibrancy.updateAllLatest",
        "title": "Saropa: Update All Dependencies (Latest)",
        "icon": "$(cloud-download)"
      },
      {
        "command": "saropaPackageVibrancy.updateAllMajor",
        "title": "Saropa: Update All Dependencies (Major Only)"
      },
      {
        "command": "saropaPackageVibrancy.updateAllMinor",
        "title": "Saropa: Update All Dependencies (Minor Only)"
      },
      {
        "command": "saropaPackageVibrancy.updateAllPatch",
        "title": "Saropa: Update All Dependencies (Patch Only)"
      },
      {
        "command": "saropaPackageVibrancy.showPrereleases",
        "title": "Saropa: Show Prerelease Versions",
        "icon": "$(beaker)"
      },
      {
        "command": "saropaPackageVibrancy.hidePrereleases",
        "title": "Saropa: Hide Prerelease Versions",
        "icon": "$(eye-closed)"
      },
      {
        "command": "saropaPackageVibrancy.updateToPrerelease",
        "title": "Update to Prerelease",
        "icon": "$(beaker)"
      },
      {
        "command": "saropaPackageVibrancy.generateCiConfig",
        "title": "Saropa: Generate CI Pipeline",
        "icon": "$(server-process)"
      },
      {
        "command": "saropaPackageVibrancy.addRegistryAuth",
        "title": "Saropa: Add Registry Authentication",
        "icon": "$(key)"
      },
      {
        "command": "saropaPackageVibrancy.removeRegistryAuth",
        "title": "Saropa: Remove Registry Authentication",
        "icon": "$(trash)"
      },
      {
        "command": "saropaPackageVibrancy.listRegistries",
        "title": "Saropa: List Configured Registries",
        "icon": "$(list-unordered)"
      },
      {
        "command": "saropaPackageVibrancy.comparePackages",
        "title": "Saropa: Compare Packages",
        "icon": "$(diff)"
      },
      {
        "command": "saropaPackageVibrancy.compareSelected",
        "title": "Compare Selected Packages",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "saropaPackageVibrancy.scan",
          "when": "view == saropaPackageVibrancy.packages && !saropaPackageVibrancy.isScanning",
          "group": "navigation@1"
        },
        {
          "command": "saropaPackageVibrancy.about",
          "when": "view == saropaPackageVibrancy.packages",
          "group": "navigation@2"
        },
        {
          "command": "saropaPackageVibrancy.planUpgrades",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults && !saropaPackageVibrancy.isScanning",
          "group": "navigation@3"
        },
        {
          "command": "saropaPackageVibrancy.annotatePubspec",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults",
          "group": "navigation@4"
        },
        {
          "command": "saropaPackageVibrancy.suppressByCategory",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults",
          "group": "suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.unsuppressAll",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults",
          "group": "suppress@2"
        },
        {
          "command": "saropaPackageVibrancy.sortDependencies",
          "when": "view == saropaPackageVibrancy.packages && !saropaPackageVibrancy.isScanning",
          "group": "organize@1"
        },
        {
          "command": "saropaPackageVibrancy.updateAllLatest",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults && !saropaPackageVibrancy.isScanning",
          "group": "2_bulk@1"
        },
        {
          "command": "saropaPackageVibrancy.updateAllMajor",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults && !saropaPackageVibrancy.isScanning",
          "group": "2_bulk@2"
        },
        {
          "command": "saropaPackageVibrancy.updateAllMinor",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults && !saropaPackageVibrancy.isScanning",
          "group": "2_bulk@3"
        },
        {
          "command": "saropaPackageVibrancy.updateAllPatch",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults && !saropaPackageVibrancy.isScanning",
          "group": "2_bulk@4"
        },
        {
          "command": "saropaPackageVibrancy.generateCiConfig",
          "when": "view == saropaPackageVibrancy.packages && saropaPackageVibrancy.hasResults",
          "group": "3_ci@1"
        }
      ],
      "editor/title": [
        {
          "command": "saropaPackageVibrancy.hideCodeLens",
          "when": "resourceFilename == pubspec.yaml && saropaPackageVibrancy.codeLensEnabled",
          "group": "navigation"
        },
        {
          "command": "saropaPackageVibrancy.showCodeLens",
          "when": "resourceFilename == pubspec.yaml && !saropaPackageVibrancy.codeLensEnabled",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "saropaPackageVibrancy.sortDependencies",
          "when": "resourceFilename == pubspec.yaml",
          "group": "saropa@1"
        }
      ],
      "commandPalette": [
        {
          "command": "saropaPackageVibrancy.showCodeLens",
          "when": "!saropaPackageVibrancy.codeLensEnabled"
        },
        {
          "command": "saropaPackageVibrancy.hideCodeLens",
          "when": "saropaPackageVibrancy.codeLensEnabled"
        },
        {
          "command": "saropaPackageVibrancy.updateFromCodeLens",
          "when": "false"
        },
        {
          "command": "saropaPackageVibrancy.focusPackageInTree",
          "when": "false"
        },
        {
          "command": "saropaPackageVibrancy.showPrereleases",
          "when": "!saropaPackageVibrancy.showPrereleases"
        },
        {
          "command": "saropaPackageVibrancy.hidePrereleases",
          "when": "saropaPackageVibrancy.showPrereleases"
        },
        {
          "command": "saropaPackageVibrancy.updateToPrerelease",
          "when": "false"
        },
        {
          "command": "saropaPackageVibrancy.compareSelected",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "saropaPackageVibrancy.goToPackage",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "inline"
        },
        {
          "command": "saropaPackageVibrancy.goToPackage",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@1"
        },
        {
          "command": "saropaPackageVibrancy.openOnPubDev",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@2"
        },
        {
          "command": "saropaPackageVibrancy.updateToLatest",
          "when": "viewItem == vibrancyPackageUpdatable",
          "group": "navigation@3"
        },
        {
          "command": "saropaPackageVibrancy.copyAsJson",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "navigation@4"
        },
        {
          "command": "saropaPackageVibrancy.upgradeAndTest",
          "when": "viewItem == vibrancyPackageUpdatable",
          "group": "navigation@5"
        },
        {
          "command": "saropaPackageVibrancy.suppressPackage",
          "when": "viewItem =~ /^vibrancyPackage(Unused)?(Updatable)?$/",
          "group": "2_suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.unsuppressPackage",
          "when": "viewItem =~ /Suppressed/",
          "group": "2_suppress@1"
        },
        {
          "command": "saropaPackageVibrancy.openUrl",
          "when": "viewItem == vibrancyDetailLink",
          "group": "inline"
        },
        {
          "command": "saropaPackageVibrancy.commentOutUnused",
          "when": "viewItem =~ /vibrancyPackageUnused/",
          "group": "3_unused@1"
        },
        {
          "command": "saropaPackageVibrancy.deleteUnused",
          "when": "viewItem =~ /vibrancyPackageUnused/",
          "group": "3_unused@2"
        },
        {
          "command": "saropaPackageVibrancy.logDetails",
          "when": "viewItem =~ /vibrancyPackage/",
          "group": "4_output@1"
        },
        {
          "command": "saropaPackageVibrancy.compareSelected",
          "when": "viewItem =~ /vibrancyPackage/ && listMultiSelection",
          "group": "5_compare@1"
        },
        {
          "command": "saropaPackageVibrancy.updateToPrerelease",
          "when": "viewItem == vibrancyPrerelease",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Saropa Package Vibrancy",
      "properties": {
        "saropaPackageVibrancy.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token for increased API rate limits (60/hr without, 5000/hr with)"
        },
        "saropaPackageVibrancy.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan when a Flutter project is opened"
        },
        "saropaPackageVibrancy.includeDevDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Include dev_dependencies in the vibrancy scan"
        },
        "saropaPackageVibrancy.includeOverriddenPackages": {
          "type": "boolean",
          "default": true,
          "description": "Include dependency_overrides (path/git) in the vibrancy scan for security and health checks"
        },
        "saropaPackageVibrancy.cacheTtlHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 168,
          "description": "Cache TTL in hours for API responses"
        },
        "saropaPackageVibrancy.suppressedPackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to suppress from vibrancy diagnostics and hover (still scanned, shown dimmed in tree)"
        },
        "saropaPackageVibrancy.allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to skip during vibrancy scan (e.g. internal packages)"
        },
        "saropaPackageVibrancy.repoOverrides": {
          "type": "object",
          "default": {},
          "description": "Override GitHub repository URLs for packages where pub.dev data is wrong. Keys are package names, values are GitHub URLs (e.g. { \"my_pkg\": \"https://github.com/org/my_pkg\" })",
          "additionalProperties": {
            "type": "string"
          }
        },
        "saropaPackageVibrancy.registries": {
          "type": "object",
          "default": {},
          "description": "Registry configuration for private Pub servers. Tokens are stored securely in VS Code Secret Storage.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this registry"
              },
              "packages": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Package names hosted on this registry (empty = auto-detect from pubspec)"
              }
            }
          }
        },
        "saropaPackageVibrancy.showLockDiffNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification summarizing lock file changes after each scan"
        },
        "saropaPackageVibrancy.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show vibrancy score badges as CodeLens annotations above each dependency in pubspec.yaml"
        },
        "saropaPackageVibrancy.enableAdoptionGate": {
          "type": "boolean",
          "default": true,
          "description": "Show inline vibrancy badges for new packages being added to pubspec.yaml"
        },
        "saropaPackageVibrancy.codeLensDetail": {
          "type": "string",
          "enum": [
            "minimal",
            "standard",
            "full"
          ],
          "default": "standard",
          "enumDescriptions": [
            "Score and category only",
            "Score, category, and update status",
            "Score, category, archive size, update status, and alerts"
          ],
          "description": "Controls how much detail the CodeLens annotations show"
        },
        "saropaPackageVibrancy.indicators": {
          "type": "object",
          "default": {},
          "description": "Custom symbols for status indicators. Keys: vibrant, quiet, legacyLocked, endOfLife, updateAvailable, prerelease, warning, error, unused, suppressed, upToDate",
          "properties": {
            "vibrant": {
              "type": "string",
              "description": "Indicator for vibrant packages (default: \ud83d\udfe2)"
            },
            "quiet": {
              "type": "string",
              "description": "Indicator for quiet packages (default: \ud83d\udfe1)"
            },
            "legacyLocked": {
              "type": "string",
              "description": "Indicator for legacy-locked packages (default: \ud83d\udfe0)"
            },
            "endOfLife": {
              "type": "string",
              "description": "Indicator for end-of-life packages (default: \ud83d\udd34)"
            },
            "updateAvailable": {
              "type": "string",
              "description": "Indicator for available updates (default: \u2b06)"
            },
            "prerelease": {
              "type": "string",
              "description": "Indicator for prerelease versions (default: \ud83e\uddea)"
            },
            "warning": {
              "type": "string",
              "description": "Indicator for warnings (default: \u26a0)"
            },
            "unused": {
              "type": "string",
              "description": "Indicator for unused packages (default: \ud83d\udc7b)"
            },
            "upToDate": {
              "type": "string",
              "description": "Indicator for up-to-date packages (default: \u2713)"
            }
          }
        },
        "saropaPackageVibrancy.indicatorStyle": {
          "type": "string",
          "enum": [
            "emoji",
            "text",
            "both",
            "none"
          ],
          "default": "emoji",
          "enumDescriptions": [
            "Show emoji only (\ud83d\udfe2)",
            "Show text only (Vibrant)",
            "Show both (\ud83d\udfe2 Vibrant)",
            "Show score only, no indicator"
          ],
          "description": "How to display status indicators in CodeLens"
        },
        "saropaPackageVibrancy.sortSdkFirst": {
          "type": "boolean",
          "default": true,
          "description": "Keep SDK dependencies (flutter, flutter_test) at the top when sorting"
        },
        "saropaPackageVibrancy.endOfLifeDiagnostics": {
          "type": "string",
          "enum": [
            "none",
            "hint",
            "smart"
          ],
          "default": "none",
          "enumDescriptions": [
            "No diagnostics for end-of-life packages (view in sidebar only)",
            "Show as Hint (subtle underline)",
            "Show as Warning only when a replacement is known, otherwise Hint"
          ],
          "description": "How to display end-of-life package diagnostics in the editor"
        },
        "saropaPackageVibrancy.weights.resolutionVelocity": {
          "type": "number",
          "default": 0.5,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Resolution Velocity in V_score (default 0.5)"
        },
        "saropaPackageVibrancy.weights.engagementLevel": {
          "type": "number",
          "default": 0.4,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Engagement Level in V_score (default 0.4)"
        },
        "saropaPackageVibrancy.weights.popularity": {
          "type": "number",
          "default": 0.1,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight for Popularity in V_score (default 0.1)"
        },
        "saropaPackageVibrancy.publisherTrustBonus": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 25,
          "description": "Max bonus for major trusted publishers like dart.dev (0 to disable). Verified publishers get 1/3, no publisher gets \u22121/3 penalty."
        },
        "saropaPackageVibrancy.upgradeAutoCommit": {
          "type": "boolean",
          "default": false,
          "description": "Auto-commit each successful upgrade step (creates one commit per package)"
        },
        "saropaPackageVibrancy.upgradeSkipTests": {
          "type": "boolean",
          "default": false,
          "description": "Skip flutter test gates during upgrade execution (faster but less safe)"
        },
        "saropaPackageVibrancy.upgradeMaxSteps": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of upgrade steps to execute in one run"
        },
        "saropaPackageVibrancy.bulkUpdateConfirmation": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before bulk updating dependencies"
        },
        "saropaPackageVibrancy.watchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable background polling for new package versions"
        },
        "saropaPackageVibrancy.watchIntervalHours": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 24,
          "description": "How often to check for new package versions (in hours)"
        },
        "saropaPackageVibrancy.watchFilter": {
          "type": "string",
          "enum": [
            "all",
            "unhealthy",
            "custom"
          ],
          "default": "all",
          "enumDescriptions": [
            "Watch all direct dependencies",
            "Only watch packages with vibrancy score below 40",
            "Only watch packages specified in watchList"
          ],
          "description": "Filter which packages to watch for new versions"
        },
        "saropaPackageVibrancy.watchList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names to watch for new versions (only used when watchFilter is 'custom')"
        },
        "saropaPackageVibrancy.annotateSectionHeaders": {
          "type": "boolean",
          "default": true,
          "description": "Insert decorative section headers above major pubspec sections (dependencies, dev_dependencies, dependency_overrides)"
        },
        "saropaPackageVibrancy.treeGrouping": {
          "type": "string",
          "enum": [
            "none",
            "section"
          ],
          "default": "none",
          "enumDescriptions": [
            "Flat list sorted by vibrancy score (worst first)",
            "Group by pubspec section (dependencies, dev_dependencies)"
          ],
          "description": "How to group packages in the tree view"
        },
        "saropaPackageVibrancy.showPrereleases": {
          "type": "boolean",
          "default": false,
          "description": "Show prerelease versions (dev, beta, rc) in CodeLens and tree view"
        },
        "saropaPackageVibrancy.prereleaseTagFilter": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Only show prereleases matching these tags (e.g., ['beta', 'rc']). Empty = show all prereleases."
        },
        "saropaPackageVibrancy.onSaveChanges": {
          "type": "string",
          "default": "",
          "description": "Command to run when pubspec.yaml is saved with dependency changes. Empty = disabled. Examples: 'flutter pub get', 'task:My Build Task'"
        },
        "saropaPackageVibrancy.onSaveChangesDetection": {
          "type": "string",
          "enum": [
            "any",
            "dependencies"
          ],
          "default": "dependencies",
          "enumDescriptions": [
            "Run on any pubspec.yaml save",
            "Run only when dependency sections change"
          ],
          "description": "When to trigger the on-save task"
        },
        "saropaPackageVibrancy.budget.maxDependencies": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 1,
          "description": "Maximum number of total dependencies allowed (null = no limit)"
        },
        "saropaPackageVibrancy.budget.maxTotalSizeMB": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0.1,
          "description": "Maximum total archive size in megabytes (null = no limit)"
        },
        "saropaPackageVibrancy.budget.minAverageVibrancy": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum average vibrancy score (0-100) required across all dependencies (null = no limit)"
        },
        "saropaPackageVibrancy.budget.maxEndOfLife": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "Maximum number of End-of-Life packages allowed (null = no limit)"
        },
        "saropaPackageVibrancy.budget.maxLegacyLocked": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "Maximum number of Legacy-Locked packages allowed (null = no limit)"
        },
        "saropaPackageVibrancy.budget.maxUnused": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "Maximum number of unused dependencies allowed (null = no limit)"
        },
        "saropaPackageVibrancy.enableVulnScan": {
          "type": "boolean",
          "default": true,
          "description": "Query OSV database for known vulnerabilities in dependencies"
        },
        "saropaPackageVibrancy.enableGitHubAdvisory": {
          "type": "boolean",
          "default": true,
          "description": "Query GitHub Advisory Database for additional security advisories (complements OSV)"
        },
        "saropaPackageVibrancy.vulnSeverityThreshold": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "default": "low",
          "enumDescriptions": [
            "Only show critical vulnerabilities (CVSS 9.0+)",
            "Show high and critical vulnerabilities (CVSS 7.0+)",
            "Show medium, high, and critical vulnerabilities (CVSS 4.0+)",
            "Show all vulnerabilities"
          ],
          "description": "Minimum severity level for displaying vulnerability diagnostics"
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "compile-tests": "tsc -p ./",
    "lint": "eslint src",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "pretest": "npm run compile-tests",
    "test": "mocha",
    "vscode:prepublish": "npm run package",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.15.0",
    "mocha": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "semver": "^7.7.4",
    "sinon": "^19.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0"
  }
